{
  "name": "templatus-hotwire",
  "private": true,
  "scripts": {
    "lint": "eslint --cache .",
    "format": "prettier . --write --plugin=prettier-plugin-tailwindcss",
    "tsc": "tsc --noEmit",
    "size": "bun run size-limit"
  },
  "dependencies": {
    "@honeybadger-io/js": "^6.14.0",
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "@plausible-analytics/tracker": "^0.4.5",
    "@rails/actioncable": "^8.1.300",
    "el-transition": "^0.0.7",
    "idiomorph": "^0.7.4",
    "register-service-worker": "^1.7.2",
    "timeago.js": "^4.0.2"
  },
  "version": "0.1.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.1",
    "@types/rails__actioncable": "^8.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "playwright": "^1.61.1",
    "prettier": "^3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.0",
    "vite-plugin-full-reload": "^1.2.0",
    "vite-plugin-rails": "^0.6.0",
    "vite-plugin-stimulus-hmr": "^3.0.0"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "vite"
  ],
  "size-limit": [
    {
      "limit": "55 kB",
      "path": "public/{vite,vite-dev,vite-test}/assets/*.js"
    }
  ],
  "engines": {
    "bun": "1.3.x"
  }
}
