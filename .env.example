# Hostname of the application
APP_HOST=templatus-hotwire.example.com

# Timezone
TIME_ZONE=Berlin

# Redis. One database per purpose, so that clearing the cache (FLUSHDB)
# cannot wipe the Sidekiq queues.
REDIS_CACHE_URL=redis://localhost:6379/0
REDIS_CABLE_URL=redis://localhost:6379/1
REDIS_QUEUE_URL=redis://localhost:6379/2

# Redirect to HTTPS
FORCE_SSL=true

# Optional: Analytics
# PLAUSIBLE_URL=https://plausible.io

# Optional: Honeybadger.io error tracking
# HONEYBADGER_API_KEY=1234567890

# Optional: RorVsWild performance monitoring
# RORVSWILD_API_KEY=1234567890

# Optional: Lock app with a password
# LOCKUP_CODEWORD=my-codeword
