<%#
  Pinned to the bottom: with the endlessly scrolling list there is no "end of
  page" the user could ever scroll to
%>

<footer class="border-base-300 bg-base-100/85 fixed inset-x-0 bottom-0 z-40 border-t backdrop-blur">
  <div
    class="
      text-base-content/70 mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3 text-xs sm:px-6
      sm:text-sm
    "
  >
    <div class="flex items-center gap-3">
      <a
        class="link link-hover flex items-center gap-2"
        target="_blank"
        rel="noopener noreferrer"
        href="https://github.com/templatus/templatus-hotwire"
      >
        <span class="icon-[lucide--github] size-5" aria-hidden="true"></span>

        <span class="sr-only">GitHub</span>
      </a>

      <%= render GitVersion::Component.new(
                   commit_version: Rails.configuration.x.git.commit_version,
                   commit_time: Rails.configuration.x.git.commit_time,
                 ) %>
    </div>

    <div data-controller="online-status">
      <span class="badge badge-warning badge-sm hidden gap-1" data-online-status-target="indicator">
        <span class="status status-warning"></span>
        You are offline
      </span>
    </div>

    <%= link_to 'https://ledermann.dev',
                class: 'link link-hover flex items-center gap-2',
                target: '_blank',
                rel: 'noopener noreferrer' do %>
      <svg
        class="size-5"
        viewBox="0 0 276 276"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M0 137l138 138 138-138-84-82-84 82 31 30 53-52 25 22-79 77-78-77L166 29 138 1" />
      </svg>

      <span class="font-mono">ledermann.dev</span>
    <% end %>
  </div>
</footer>
