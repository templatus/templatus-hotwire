<%= helpers.turbo_stream_from 'clicks' %>

<div
  class="grid gap-8 lg:grid-cols-[1fr_19rem] lg:items-start lg:gap-10"
  data-controller="clicks"
  data-clicks-count-value="<%= count %>"
>
  <div class="order-2 lg:order-1">
    <h2 class="border-base-300 text-base-content/70 mb-4 border-b pb-2 text-sm font-medium">
      Latest clicks
    </h2>

    <%= helpers.turbo_frame_tag 'clicks',
                                data: {
                                  action: 'turbo:before-stream-render@document->clicks#receive',
                                } do %>
      <%#
        The list slides down by one row to make room, then the new row fades in.
        Keep translate-y in sync with the height of a single click row.
      %>

      <ul
        id="list"
        class="list bg-base-100 border-base-300 rounded-box border"
        data-clicks-target="list"
        data-transition-enter="transition duration-200 ease-in"
        data-transition-enter-start="translate-y-0"
        data-transition-enter-end="translate-y-13"
      >
        <% clicks.each do |click| %>
          <%= render Click::Component.new(click: click) %>
        <% end %>
      </ul>
    <% end %>
  </div>

  <aside class="order-1 lg:sticky lg:top-24 lg:order-2">
    <%# Same header row as the list, so both columns start their box on one line %>
    <h2 class="border-base-300 text-base-content/70 mb-4 border-b pb-2 text-sm font-medium">
      Total clicks
    </h2>

    <div class="border-base-300 bg-base-100 rounded-box border p-6 text-center">
      <%# Fixed height reserves the space before the Stimulus controller fills in the number %>
      <div class="flex h-16 items-center justify-center">
        <div
          id="counter"
          class="text-primary text-6xl leading-none font-bold tabular-nums"
          data-clicks-target="counter"
          data-transition-enter="transition-transform duration-200 ease-out"
          data-transition-enter-start="scale-0"
          data-transition-enter-end="scale-100"
          data-transition-leave="transition-transform duration-200 ease-in"
          data-transition-leave-start="scale-100"
          data-transition-leave-end="scale-0"
          data-turbo-permanent="true"
        >
          &nbsp;
        </div>
      </div>

      <%= button_to 'Click me!',
                    helpers.clicks_path,
                    class: 'btn btn-primary btn-block mt-5',
                    form_class: 'w-full' %>
    </div>

    <p class="text-base-content/55 mt-4 px-1 text-xs leading-relaxed text-balance">
      Tip: open two browser windows in parallel and see what happens.
    </p>
  </aside>
</div>
