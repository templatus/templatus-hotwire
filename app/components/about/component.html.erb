<div class="space-y-14">
  <% FEATURES.each do |item| %>
    <section>
      <header class="mb-5 flex flex-wrap items-baseline gap-x-3">
        <h2 class="text-2xl font-bold tracking-tight">
          <%= item[:name] %>
        </h2>

        <span class="text-base-content/50 text-sm"><%= item[:slogan] %></span>
      </header>

      <%#
        Hairline grid instead of floating cards: cells in a row share their
        height, so the section keeps an even rhythm instead of ragged bottoms.
      %>

      <div class="border-base-300 bg-base-300 rounded-box grid gap-px overflow-hidden border sm:grid-cols-2">
        <% item[:items].each_with_index do |feature, index| %>
          <%# An odd item count would leave a blank cell, so the last one spans the full row %>
          <% last_and_odd = item[:items].size.odd? && index == item[:items].size - 1 %>

          <article class="bg-base-100 p-5 <%= 'sm:col-span-2' if last_and_odd %>">
            <h3 class="flex flex-wrap items-center gap-x-2 gap-y-1">
              <%= link_to feature[:name],
                          feature[:href],
                          class: 'link link-hover text-base font-semibold',
                          target: '_blank',
                          rel: 'noopener noreferrer' %>

              <% if (v = version_for_feature(feature)) %>
                <span class="badge badge-primary badge-soft badge-sm font-mono font-semibold"><%= v %></span>
              <% end %>
            </h3>

            <p class="text-base-content/70 mt-2 text-sm leading-relaxed">
              <%= feature[:description] %>
            </p>

            <% if feature[:gem] == 'sidekiq' %>
              <%= link_to 'Admin frontend',
                          helpers.sidekiq_web_path,
                          class: 'link link-primary link-hover mt-3 inline-block text-sm font-medium',
                          data: { turbo: false } %>
            <% end %>
          </article>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
