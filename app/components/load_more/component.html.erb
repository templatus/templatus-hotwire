<div id="<%= id %>" data-controller="load-more" data-load-more-url-value="<%= url %>">
  <% if url %>
    <div class="flex justify-center py-6" role="status">
      <span class="loading loading-dots loading-md text-base-content/40"></span>
      <span class="sr-only">Loading more clicks…</span>
    </div>
  <% end %>
</div>
