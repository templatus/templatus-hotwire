<%#
  `base-100` is the raised surface, same as the cards and the footer: the page
  gradient runs from `base-200` down, so the bar reads as sitting above it in
  both themes instead of relying on its border alone.
%>

<header class="bg-base-100/80 border-base-300 sticky top-0 z-40 border-b backdrop-blur">
  <div class="navbar mx-auto max-w-5xl gap-4 px-4 sm:px-6">
    <div class="navbar-start">
      <%= link_to helpers.root_path, class: 'flex items-center gap-3', data: { turbo_action: 'replace' } do %>
        <%= image_tag helpers.vite_asset_path('images/logo.svg'),
                      class: 'size-9',
                      alt: '',
                      width: 36,
                      height: 36 %>

        <span class="text-lg font-semibold tracking-tight whitespace-nowrap">
          Templatus <%# The edition suffix would wrap the brand onto a second line on narrow screens %>
          <span class="text-base-content/50 hidden font-normal sm:inline">Hotwire</span>
        </span>
      <% end %>
    </div>

    <div class="navbar-end gap-2">
      <%= render Tabs::Component.new do |t| %>
        <% t.with_tab text: 'Home', href: helpers.root_path %>
        <% t.with_tab text: 'About', href: helpers.about_path %>
      <% end %>

      <%= render ThemeToggle::Component.new %>
    </div>
  </div>
</header>
