<%#
  Only opacity is animated here. daisyUI centers the toast via the translate
  property (--toast-x: -50%), so animating translate-y would drop the
  horizontal centering and make the toast jump sideways. The subtle scale-in
  comes from daisyUI's own toast keyframes on the child.

  bottom-16 matches the body's pb-16, so the toast clears the fixed footer.
%>

<div
  class="toast toast-center toast-bottom bottom-16 z-50 hidden"
  data-controller="app-flash"
  data-transition-enter="transition duration-300 ease-out"
  data-transition-enter-start="opacity-0"
  data-transition-enter-end="opacity-100"
  data-transition-leave="transition duration-300 ease-in"
  data-transition-leave-start="opacity-100"
  data-transition-leave-end="opacity-0"
  data-turbo-temporary="true"
>
  <div role="alert" class="shadow-lg <%= alert_class %>">
    <span class="size-5 shrink-0 <%= icon_class %>" aria-hidden="true"></span>

    <span class="font-medium"><%= text %></span>
  </div>
</div>
