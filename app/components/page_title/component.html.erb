<%#
  The <h1> and the document title always say the same thing, so set both from
  here instead of asking every page to repeat itself.
%>
<% content_for :title, title %>

<header class="mb-10 sm:mb-14">
  <h1 class="text-4xl font-extrabold tracking-tight wrap-break-word sm:text-5xl">
    <%= title %>
  </h1>

  <%# Each page brings its own lead paragraph, so "About" no longer repeats the home page pitch %>
  <% if content? %>
    <p class="text-base-content/70 mt-4 max-w-lg text-lg leading-relaxed text-pretty">
      <%= content %>
    </p>
  <% end %>
</header>
