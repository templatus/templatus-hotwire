# Hostname of the application
APP_HOST=templatus.localhost

# Timezone
TIME_ZONE=Berlin

# Redis. One database per purpose, so that clearing the cache (FLUSHDB)
# cannot wipe the Sidekiq queues.
REDIS_CACHE_URL=redis://localhost:6379/0
REDIS_CABLE_URL=redis://localhost:6379/1
REDIS_QUEUE_URL=redis://localhost:6379/2

# Redirect to HTTPS
FORCE_SSL=true
